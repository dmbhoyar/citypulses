<div class="panel">
  <div style="display:flex;justify-content:space-between;align-items:center">
    <h1 style="margin:0">Listings</h1>
    <div>
      <%= link_to 'All', listings_path, class: 'button' %>
      <%= link_to 'Buy/Sell', listings_path(category: 'sell'), class: 'button' %>
      <%= link_to 'Rentals', listings_path(category: 'rent'), class: 'button' %>
      <%= link_to 'Services', listings_path(category: 'service'), class: 'button' %>
    </div>
  </div>

  <div class="grid" style="margin-top:12px">
    <% @listings.each do |l| %>
      <div class="card">
        <h3><%= link_to l.title, l %></h3>
        <p><%= truncate(l.description, length: 150) %></p>
        <p><strong>Price:</strong> <%= l.price.present? ? number_to_currency(l.price) : 'Contact' %></p>
        <p><strong>Contact:</strong> <%= l.contact_number.presence || '—' %></p>
        <div style="margin-top:8px">
          <%= link_to 'View', l, class: 'button' %>
          <% if user_signed_in? && (current_user == l.user || current_user.superadmin?) %>
            <%= link_to 'Edit', edit_listing_path(l), class: 'button' %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div style="margin-top:12px">
    <% if user_signed_in? %>
      <%= link_to 'Add Listing', new_listing_path, class: 'toggle-btn' %>
    <% end %>
  </div>
</div>
