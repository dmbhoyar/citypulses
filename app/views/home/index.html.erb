			<%= @silver_per_kg_spot ? "₹#{number_with_delimiter(@silver_per_kg_spot)}" : '—' %> <% if @silver_per_kg_spot.present? %><small style="color:#9e9e9e;opacity:0.8;font-size:11px;margin-left:6px">+ GST</small><% end %>
		</div>
		<div class="metal-note">
			<% if @silver_per_kg_retail.present? %>
