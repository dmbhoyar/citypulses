	</div>

	<div class="metal-card silver">
		<div class="metal-title silver">
			<span class="metal-icon" aria-hidden>
				<svg viewBox="0 0 24 24" width="20" height="20" fill="#606060" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="6" width="16" height="12" rx="2"/></svg>
			</span>
