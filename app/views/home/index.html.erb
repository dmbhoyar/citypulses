			<% end %>
		</div>
	</div>
</div>

<div class="home-wrap">
	<div class="main-col">
		<div class="panel">
			<!-- city header removed (hidden by user request) -->
			<h3 style="margin-top:16px"><%= t('layout.todays_highlights') %></h3>
			<div class="card home-card">
				<div class="card-head" style="display:flex;justify-content:space-between;align-items:center">
					<strong style="font-size:16px;color:#2e7d32"><%= t('layout.city_news') %></strong>
					<small style="color:#666">Local headlines for your city</small>
				</div>
				<div class="card-body">
				<% if defined?(@city_news) && @city_news.present? %>
					<ul>
						<% @city_news.each do |item| %>
							<li style="margin-bottom:6px">
																<% display_title = (ENV['ENABLE_TRANSLATION'] == '1') ? translate_api_text(item[:title]) : item[:title] %>
																<%= link_to display_title, item[:link], target: '_blank', rel: 'noopener' %>
																<%# quick external translate option that opens Google Translate in a new tab (no server cost) %>
																<% if I18n.locale.to_s != 'en' %>
																	<small style="margin-left:6px"><a href="<%= external_translate_url(item[:link], I18n.locale) %>" target="_blank" rel="noopener">Translate</a></small>
																<% end %>
								<% if item[:source] || item[:pubDate] %>
									<div style="font-size:11px;color:#777;margin-top:3px">
										<% if item[:source] %> <%= item[:source] %> <% end %>
										<% if item[:pubDate] %> • <%= Date.parse(item[:pubDate]).strftime('%d %b %H:%M') rescue item[:pubDate] %> <% end %>
									</div>
								<% end %>
							</li>
						<% end %>
					</ul>
				<% elsif @offers.present? %>
					<ul>
						<% @offers.each do |o| %>
							<li><%= link_to o.title, update_path(o) %></li>
						<% end %>
					</ul>
				<% else %>
					<div><%= t('layout.no_local_news') %></div>
				<% end %>
				</div>
			</div>

			<div class="card" style="padding:16px;margin-top:16px">
				<strong style="font-size:18px;display:block;margin-bottom:12px">
					<%= t('layout.market_wise_commodity_prices') %>
				</strong>

				<% if @market_rates.present? %>

					<% @market_rates.each do |market, commodities| %>

					<div style="margin-bottom:18px">

						<h4 style="margin-bottom:8px;color:#2e7d32">
						<%= market %>
						</h4>

						<table style="width:100%;border-collapse:collapse;font-size:15px">

						<thead>
							<tr style="background:#f5f5f5">
							<th style="text-align:left;padding:6px">Commodity</th>
							<th style="text-align:left;padding:6px">Variety</th>
							<th style="text-align:left;padding:6px">Min</th>
							<th style="text-align:left;padding:6px">Max</th>
							<th style="text-align:left;padding:6px">Modal</th>
							<th style="text-align:left;padding:6px">Date</th>
							</tr>
						</thead>

						<tbody>

						<% commodities.each do |commodity, rows| %>
						<% rows.each do |r| %>

							<tr style="border-bottom:1px solid #eee">

							<td style="padding:6px">
								<%= translate_domain_text(commodity) %>
							</td>

							<td style="padding:6px">
								<%= translate_domain_text(r[:variety] || '-') %>
							</td>

							<td style="padding:6px">
								<%= number_with_precision(r[:min_price], precision:0) %>
							</td>

							<td style="padding:6px">
								<%= number_with_precision(r[:max_price], precision:0) %>
							</td>

							<td style="padding:6px;font-weight:600;color:#007bff">
								<%= number_with_precision(r[:modal_price], precision:0) %>
							</td>

							<td style="padding:6px;color:#666">
								<%= Date.strptime(r[:date], '%d/%m/%Y').strftime('%d %b') rescue r[:date] %>
							</td>

							</tr>

						<% end %>
						<% end %>

					</tbody>

					</table>

				</div>

				<% end %>

			<% else %>

				<div>No market-wise data available.</div>

			<% end %>
			</div>

			<div class="card">
				<strong>Farming Notes</strong>
				<% if @farmings.present? %>
					<ul>
						<% @farmings.each do |f| %>
							<li><%= link_to f.title, farming_path(f) %></li>
						<% end %>
					</ul>
				<% else %>
					<div>No farming notes.</div>
				<% end %>
			</div>
		</div>
	</div>

	<div class="side-col">
		<div class="panel">
			<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px">
				<strong style="display:block">Weather (3-day)</strong>
				<div style="text-align:right">
					<% if @metals && (@metals[:gold] || @metals[:silver]) %>
						<small style="display:block">Gold: <strong><%= @metals[:gold] ? "₹#{number_with_precision(@metals[:gold], precision:2)}" : '—' %></strong> /g</small>
						<small style="display:block">Silver: <strong><%= @metals[:silver] ? "₹#{number_with_precision(@metals[:silver], precision:2)}" : '—' %></strong> /g</small>
						<% if @metals_meta && @metals_meta['usd_to_inr'] %>
							<small style="display:block;color:#666;font-size:11px">FX: <%= @metals_meta['usd_to_inr'] %> (source: <%= @metals_meta['source'] %>)</small>
						<% end %>
					<% else %>
						<small>No metals data</small>
					<% end %>
				</div>
			</div>
			<% if @weather && @weather[:days].present? %>
				<ul style="list-style:none;padding-left:0">
				<% @weather[:days].each do |d| %>
					<li style="padding:6px 0;border-bottom:1px solid #eee;display:flex;justify-content:space-between;align-items:center">
						<div style="font-size:14px;color:#333">
							<%= Date.parse(d[:date]).strftime('%a %d %b') rescue d[:date] %>
						</div>
						<div style="text-align:right;color:#555">
							<div>Max: <strong><%= number_with_precision(d[:temp_max], precision:0) %>°C</strong></div>
							<div>Min: <%= number_with_precision(d[:temp_min], precision:0) %>°C</div>
							<div style="font-size:12px;color:#777">Precip: <%= number_with_precision(d[:precipitation] || 0, precision:1) %> mm</div>
						</div>
					</li>
				<% end %>
				</ul>
			<% else %>
				<div>No weather data available.</div>
			<% end %>
		</div>

		<div id="side-panel" class="panel" style="display:none">
			<h4>Latest Updates</h4>
			<% if @updates.present? %>
				<ul>
					<% @updates.each do |u| %>
						<li><%= link_to u.title, update_path(u) %></li>
					<% end %>
				</ul>
			<% else %>
				<div>No updates.</div>
			<% end %>

			<h4 style="margin-top:12px">Jobs</h4>
			<% if @jobs.present? %>
				<ul>
					<% @jobs.each do |j| %>
						<li><%= link_to j.title, job_path(j) %></li>
					<% end %>
				</ul>
			<% else %>
				<div>No jobs.</div>
			<% end %>
		</div>
	</div>
</div>

<script>
	function togglePanel(){
		var p = document.getElementById('side-panel');
		if(!p) return;
		p.style.display = p.style.display === 'none' ? 'block' : 'none';
	}

	function useLocation(){
		if(!navigator.geolocation){ alert('Geolocation not supported'); return; }
		navigator.geolocation.getCurrentPosition(function(pos){
			var lat = pos.coords.latitude; var lng = pos.coords.longitude;
				var url = new URL(window.location.href);
				url.searchParams.set('use_location','1');
				url.searchParams.set('lat',lat);
				url.searchParams.set('lng',lng);
				window.location = url.toString();
		}, function(){ alert('Unable to retrieve your location'); });
	}
</script>

</script>

