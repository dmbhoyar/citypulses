			<% elsif @gold_22_per_10g_spot.present? %>
				Per 10g: <strong><%= "₹#{number_with_delimiter(@gold_22_per_10g_spot)}" %></strong>
			<% end %>
		</div>
	</div>

	<div class="metal-card">
		<div class="metal-title">
			<span class="metal-icon" aria-hidden>
				<svg viewBox="0 0 24 24" width="20" height="20" fill="#b8860b" xmlns="http://www.w3.org/2000/svg"><polygon points="12,2 15,11 23,11 17,16 19,24 12,19 5,24 7,16 1,11 9,11"/></svg>
