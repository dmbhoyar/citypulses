		</div>
		<div class="metal-value"> 
			<%= @silver_per_10g_spot ? "₹#{number_with_delimiter(@silver_per_10g_spot)}" : '—' %> <% if @silver_per_10g_spot.present? %><small style="color:#9e9e9e;opacity:0.8;font-size:11px;margin-left:6px">+ GST</small><% end %>
		</div>
		<div class="metal-note">
			<% if @silver_per_10g_retail.present? %>
				Retail: <strong><%= "₹#{number_with_delimiter(@silver_per_10g_retail)}" %></strong> <small style="color:#9e9e9e;opacity:0.8;font-size:11px;margin-left:6px">+ GST</small>
			<% end %>
		</div>
	</div>

	<div class="metal-card silver">
		<div class="metal-title silver">
			<span class="metal-icon" aria-hidden>
				<svg viewBox="0 0 24 24" width="20" height="20" fill="#606060" xmlns="http://www.w3.org/2000/svg"><polygon points="12,2 15,11 23,11 17,16 19,24 12,19 5,24 7,16 1,11 9,11"/></svg>
