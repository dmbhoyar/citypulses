		</div>
		<div class="metal-value"> 
			<%= @gold_18_per_g ? "₹#{number_with_delimiter(@gold_18_per_g)}" : '—' %> <% if @gold_18_per_g.present? %><small style="color:#9e9e9e;opacity:0.8;font-size:11px;margin-left:6px">+ GST</small><% end %>
		</div>
		<div class="metal-note">
			<% if @gold_18_per_10g_retail.present? %>
				Per 10g (retail): <strong><%= "₹#{number_with_delimiter(@gold_18_per_10g_retail)}" %></strong> <small style="color:#9e9e9e;opacity:0.8;font-size:11px;margin-left:6px">+ GST</small>
			<% elsif @gold_18_per_10g_spot.present? %>
				Per 10g: <strong><%= "₹#{number_with_delimiter(@gold_18_per_10g_spot)}" %></strong>
			<% end %>
		</div>
	</div>

	<div class="metal-card silver">
		<div class="metal-title silver">
			<span class="metal-icon" aria-hidden>
				<svg viewBox="0 0 24 24" width="20" height="20" fill="#606060" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10"/></svg>
			</span>
			Silver /g
		</div>
		<div class="metal-value"> 
			<%= @metals && @metals[:silver] ? "₹#{number_with_delimiter(@metals[:silver].round(2))}" : '—' %>
		</div>
		<div class="metal-note">
			<% if @silver_per_10g_retail.present? %>
