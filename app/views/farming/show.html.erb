<h1><%= @farming.title %></h1>
<div><small><%= @farming.city&.name %> — <%= @farming.created_at.strftime('%d %b %Y') %></small></div>
<div><%= simple_format(@farming.content) %></div>

<% if user_signed_in? %>
  <%= link_to 'Back', farming_index_path, class: 'toggle-btn' %>
<% end %>
<h2><%= @farming.title %></h2>
<p><strong>City:</strong> <%= @farming.city.name %></p>
<div><%= simple_format @farming.content %></div>
<%= link_to 'Edit', edit_farming_path(@farming), class: 'button' %>
<%= link_to 'Delete', farming_path(@farming), method: :delete, data: { confirm: 'Are you sure?' }, class: 'button danger' %>