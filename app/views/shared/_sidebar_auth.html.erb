<div class="sidebar-user" role="navigation" aria-label="User">
  <% if user_signed_in? %>
    <div class="user-top">
      <div class="user-avatar"><%= (current_user.first_name || current_user.email)[0].to_s.upcase %></div>
      <div class="user-info">
        <div class="user-name"><%= current_user.full_name %></div>
        <div class="user-email"><%= current_user.email %></div>
      </div>
    </div>
    <div class="user-actions">
      <%= link_to 'Profile', edit_user_registration_path, class: 'button' %>
      <%= button_to 'Logout', destroy_user_session_path, method: :delete, form: { class: 'logout-form' }, class: 'button primary' %>
    </div>
  <% else %>
    <div class="auth-links">
      <%= link_to 'Login', new_user_session_path, class: 'button' %>
      <%= link_to 'Sign Up', new_user_registration_path, class: 'button primary' %>
    </div>
  <% end %>
</div>
