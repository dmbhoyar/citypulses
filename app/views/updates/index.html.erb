
<style>
  .updates-newspaper {
    max-width: 700px;
    margin: 0 auto;
    background: #fffde7;
    border-radius: 16px;
    box-shadow: 0 4px 24px #e0f7fa99;
    padding: 2.5rem 2rem;
    font-family: 'Georgia', serif;
  }
  .updates-header {
    text-align: center;
    font-size: 2.2rem;
    font-weight: bold;
    color: #ff9800;
    margin-bottom: 1.5rem;
    letter-spacing: 0.04em;
  }
  .updates-new-btn {
    display: block;
    margin: 0 auto 2rem auto;
    background: linear-gradient(90deg, #ffb300 0%, #81d4fa 100%);
    color: #fff;
    font-weight: bold;
    border: none;
    border-radius: 8px;
    padding: 0.8rem 2.2rem;
    font-size: 1.1rem;
    cursor: pointer;
    transition: background 0.2s;
    text-decoration: none;
  }
  .updates-new-btn:hover {
    background: linear-gradient(90deg, #81d4fa 0%, #ffb300 100%);
  }
  .updates-list {
    list-style: none;
    padding: 0;
  }
  .updates-item {
    margin-bottom: 2.2rem;
    padding-bottom: 1.2rem;
    border-bottom: 1px solid #b2ebf2;
  }
  .updates-headline {
    font-size: 1.6rem;
    font-weight: bold;
    color: #00796b;
    margin-bottom: 0.4rem;
    letter-spacing: 0.03em;
  }
  .updates-meta {
    font-size: 1rem;
    color: #757575;
    margin-bottom: 0.6rem;
  }
  .updates-content {
    font-size: 1.2rem;
    color: #333;
    line-height: 1.7;
    background: #e0f7fa;
    border-radius: 8px;
    padding: 0.8rem 1rem;
    margin-bottom: 0.4rem;
  }
  @media (max-width: 600px) {
    .updates-newspaper {
      padding: 1.2rem 0.5rem;
    }
    .updates-header {
      font-size: 1.3rem;
    }
    .updates-headline {
      font-size: 1.1rem;
    }
    .updates-content {
      font-size: 1rem;
    }
  }
</style>

<div class="updates-newspaper">
  <div class="updates-header">Updates & News Headlines</div>
  <%= link_to 'New Update', new_update_path, class: 'updates-new-btn' %>
  <ul class="updates-list">
    <% @updates.each do |update| %>
      <li class="updates-item">
        <div class="updates-headline">
          <%= link_to update.title, update_path(update), style: 'color: #00796b; text-decoration: underline;' %>
        </div>
        <div class="updates-meta">
          City: <%= update.city.name %> | Published: <%= update.created_at.strftime('%d %B %Y') %>
        </div>
        <div class="updates-content">
          <%= truncate(update.content, length: 220, separator: ' ') %>
        </div>
      </li>
    <% end %>
  </ul>
</div>