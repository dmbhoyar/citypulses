
<div class="panel max-w-lg mx-auto">
  <div class="panel-heading text-center">Updates & News Headlines</div>
  <div class="panel-body">
    <div class="mb-4 text-center">
      <%= link_to 'New Update', new_update_path, class: 'btn-primary' %>
    </div>
    <ul class="space-y-6">
      <% @updates.each do |update| %>
        <li class="card">
          <div class="card-body">
            <h3 class="card-title">
              <%= link_to update.title, update_path(update), class: 'link' %>
            </h3>
            <div class="text-muted text-sm mb-2">
              <strong>City:</strong> <%= update.city&.name || 'All' %> • <%= update.created_at.strftime('%d %B %Y') %>
            </div>
            <p class="mb-0"><%= truncate(strip_tags(update.content), length: 220, separator: ' ') %></p>
          </div>
          <div class="card-footer">
            <%= link_to 'Read more', update_path(update), class: 'btn-link' %>
            <%= link_to 'Edit', edit_update_path(update), class: 'btn-secondary ml-2' if policy(update).edit? rescue nil %>
          </div>
        </li>
      <% end %>
    </ul>
  </div>
</div>